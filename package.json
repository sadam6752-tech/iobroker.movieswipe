  "author": {
    "name": "sadam6752-tech",
    "email": "sadam6752@gmail.com"
  },
  "homepage": "https://github.com/sadam6752-tech/ioBroker.movieswipe",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "movieswipe",
    "movies",
    "pwa",
    "kinopoisk",
    "multimedia"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sadam6752-tech/ioBroker.movieswipe.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.2.3",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "mocha": "^11.7.5"
  },
  "main": "main.js",
  "files": [
    "admin/",
    "lib/",
    "scripts/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules)/**/*.test.js,*.test.js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "lint": "eslint .",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev": "dev-server watch default",
    "dev:run": "dev-server run default",
    "dev:debug": "dev-server debug default",
    "dev-upload": "dev-server upload default"
