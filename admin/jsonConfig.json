{
  "i18n": true,
  "type": "tabs",
  "items": {
    "general": {
      "type": "panel",
      "label": "General Settings",
      "items": {
        "_port": {
          "type": "header",
          "text": "Web Server",
          "size": 3
        },
        "bind": {
          "type": "interface",
          "label": "Bind IP address",
          "help": "Network interface to bind the web server to. Use 0.0.0.0 to listen on all interfaces.",
          "ignoreLoopback": false,
          "ignoreInternal": false,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "port": {
          "type": "number",
          "label": "Port",
          "min": 1024,
          "max": 65535,
          "default": 3000,
          "help": "Port for the web server (PWA application)",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "_apiKeys": {
          "type": "header",
          "text": "API Configuration",
          "size": 3
        },
        "apiKeys": {
          "type": "table",
          "label": "API Keys",
          "help": "Kinopoisk API keys (one or more). The adapter will use them in rotation. Press '+' to add a new key.",
          "items": [
            {
              "type": "text",
              "title": "API Key",
              "attr": "key",
              "width": "100%"
            }
          ],
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_info": {
          "type": "staticText",
          "text": "Get your API key at: https://api.kinopoisk.dev/",
          "style": {
            "fontSize": "12px",
            "fontStyle": "italic",
            "color": "#888"
          },
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        }
      }
    },
    "sync": {
      "type": "panel",
      "label": "Synchronization",
      "items": {
        "_filters": {
          "type": "header",
          "text": "Content Filters",
          "size": 3
        },
        "minRating": {
          "type": "slider",
          "label": "Minimum Rating",
          "min": 0,
          "max": 10,
          "step": 0.1,
          "default": 5.0,
          "unit": "★",
          "help": "Minimum Kinopoisk rating for movies",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "maxRating": {
          "type": "slider",
          "label": "Maximum Rating",
          "min": 0,
          "max": 10,
          "step": 0.1,
          "default": 10.0,
          "unit": "★",
          "help": "Maximum Kinopoisk rating for movies",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "minVotes": {
          "type": "number",
          "label": "Minimum Votes",
          "min": 0,
          "max": 100000,
          "step": 100,
          "default": 500,
          "help": "Minimum number of votes (popularity filter)",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "_yearRange": {
          "type": "header",
          "text": "Year Range",
          "size": 3
        },
        "yearRangeStart": {
          "type": "number",
          "label": "Start Year",
          "min": 1900,
          "max": 2030,
          "default": 2020,
          "help": "Starting year for movie search",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "yearRangeEnd": {
          "type": "number",
          "label": "End Year",
          "min": 1900,
          "max": 2030,
          "default": 2026,
          "help": "Ending year for movie search",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "_advanced": {
          "type": "header",
          "text": "Advanced Settings",
          "size": 3
        },
        "maxRequestsPerRun": {
          "type": "number",
          "label": "Max Requests per Run",
          "min": 1,
          "max": 1000,
          "default": 250,
          "help": "Maximum API requests per synchronization run (default: 250 for free tier, up to 1000 for premium)",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "dailyRequestLimit": {
          "type": "number",
          "label": "Daily Request Limit",
          "min": 1,
          "max": 10000,
          "default": 200,
          "help": "Total API requests allowed per day (default: 200 for free tier, higher for premium keys)",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "autoSync": {
          "type": "checkbox",
          "label": "Auto Sync",
          "help": "Automatically synchronize on adapter start",
          "default": false,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "syncInterval": {
          "type": "number",
          "label": "Sync Interval",
          "min": 1,
          "max": 168,
          "default": 24,
          "unit": "hours",
          "help": "Interval between automatic synchronizations (if Auto Sync is enabled)",
          "hidden": "!data.autoSync",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "preserveSyncProgress": {
          "type": "checkbox",
          "label": "Continue sync from last position",
          "help": "If enabled, sync will continue from where it stopped. If disabled, sync will always start from the beginning.",
          "default": true,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "preserveDatabase": {
          "type": "checkbox",
          "label": "Preserve existing database on update",
          "help": "If enabled, your custom database will not be overwritten when updating the adapter. Disable to reset to default database.",
          "default": true,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        }
      }
    },
    "status": {
      "type": "panel",
      "label": "Status",
      "items": {
        "_serverStatus": {
          "type": "header",
          "text": "Web Server Status",
          "size": 3
        },
        "_serverInfo": {
          "type": "staticText",
          "text": "Application URL (based on current settings):",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_serverUrl": {
          "type": "pattern",
          "pattern": "http://${data.bind || '0.0.0.0'}:${data.port || 3000}",
          "copyToClipboard": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_serverNote": {
          "type": "staticText",
          "text": "If bind is 0.0.0.0, use your host IP address to open the app. Check 'server.url' state for the actual URL.",
          "style": { "fontSize": "12px", "fontStyle": "italic", "color": "#888" },
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_dbHeader": {
          "type": "header",
          "text": "Database Backup",
          "size": 3
        },
        "_dbDownloadInfo": {
          "type": "staticText",
          "text": "Backup Manager URL:",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_dbBackupUrl": {
          "type": "pattern",
          "pattern": "http://${data.bind || '0.0.0.0'}:${data.port || 3000}/backup.html",
          "copyToClipboard": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_dbDownloadInfo2": {
          "type": "staticText",
          "text": "Direct download URL:",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_dbDownloadUrl": {
          "type": "pattern",
          "pattern": "http://${data.bind || '0.0.0.0'}:${data.port || 3000}/api/db/download",
          "copyToClipboard": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_syncStatus": {
          "type": "header",
          "text": "Synchronization Status",
          "size": 3
        },
        "_totalMoviesInfo": {
          "type": "staticText",
          "text": "Total movies in database: Check 'sync.totalMovies' state in Objects tab",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_syncInfo": {
          "type": "staticText",
          "text": "Use the 'sync.start' state to trigger synchronization. After sync completes, refresh the app (F5) to see new movies.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_help": {
          "type": "header",
          "text": "Help",
          "size": 3
        },
        "_helpText": {
          "type": "staticText",
          "text": "For more information, visit the <a href='https://github.com/sadam6752-tech/ioBroker.movieswipe' target='_blank'>GitHub repository</a>.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        }
      }
    }
  }
}
