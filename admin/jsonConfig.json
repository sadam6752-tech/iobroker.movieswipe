{
  "i18n": true,
  "type": "tabs",
  "items": {
    "general": {
      "type": "panel",
      "label": "label_general_settings",
      "items": {
        "_port": {
          "type": "header",
          "text": "label_web_server",
          "size": 3
        },
        "port": {
          "type": "number",
          "label": "label_port",
          "min": 1024,
          "max": 65535,
          "default": 3000,
          "help": "label_port_help",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "_apiKeys": {
          "type": "header",
          "text": "label_api_configuration",
          "size": 3
        },
        "apiKeys": {
          "type": "table",
          "label": "label_api_keys",
          "help": "label_api_keys_help",
          "items": [
            {
              "type": "text",
              "title": "label_api_key",
              "attr": "key",
              "width": "100%"
            }
          ],
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_info": {
          "type": "staticText",
          "text": "label_get_api_key",
          "style": {
            "fontSize": "12px",
            "fontStyle": "italic",
            "color": "#888"
          },
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        }
      }
    },
    "sync": {
      "type": "panel",
      "label": "label_synchronization",
      "items": {
        "_filters": {
          "type": "header",
          "text": "label_content_filters",
          "size": 3
        },
        "minRating": {
          "type": "slider",
          "label": "label_minimum_rating",
          "min": 0,
          "max": 10,
          "step": 0.1,
          "default": 5.0,
          "unit": "★",
          "help": "label_minimum_rating_help",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "maxRating": {
          "type": "slider",
          "label": "label_maximum_rating",
          "min": 0,
          "max": 10,
          "step": 0.1,
          "default": 10.0,
          "unit": "★",
          "help": "label_maximum_rating_help",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "minVotes": {
          "type": "number",
          "label": "label_minimum_votes",
          "min": 0,
          "max": 100000,
          "step": 100,
          "default": 500,
          "help": "label_minimum_votes_help",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "_yearRange": {
          "type": "header",
          "text": "label_year_range",
          "size": 3
        },
        "yearRangeStart": {
          "type": "number",
          "label": "label_start_year",
          "min": 1900,
          "max": 2030,
          "default": 2020,
          "help": "label_start_year_help",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "yearRangeEnd": {
          "type": "number",
          "label": "label_end_year",
          "min": 1900,
          "max": 2030,
          "default": 2026,
          "help": "label_end_year_help",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "_advanced": {
          "type": "header",
          "text": "label_advanced_settings",
          "size": 3
        },
        "maxRequestsPerRun": {
          "type": "number",
          "label": "label_max_requests_per_run",
          "min": 1,
          "max": 1000,
          "default": 250,
          "help": "label_max_requests_per_run_help",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "dailyRequestLimit": {
          "type": "number",
          "label": "label_daily_request_limit",
          "min": 1,
          "max": 10000,
          "default": 200,
          "help": "label_daily_request_limit_help",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "autoSync": {
          "type": "checkbox",
          "label": "label_auto_sync",
          "help": "label_auto_sync_help",
          "default": false,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "syncInterval": {
          "type": "number",
          "label": "label_sync_interval",
          "min": 1,
          "max": 168,
          "default": 24,
          "unit": "hours",
          "help": "label_sync_interval_help",
          "hidden": "!data.autoSync",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        }
      }
    },
    "status": {
      "type": "panel",
      "label": "label_status",
      "items": {
        "_serverStatus": {
          "type": "header",
          "text": "label_web_server_status",
          "size": 3
        },
        "_serverInfo": {
          "type": "staticText",
          "text": "label_server_url",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_syncStatus": {
          "type": "header",
          "text": "label_synchronization_status",
          "size": 3
        },
        "_totalMovies": {
          "type": "staticText",
          "text": "label_total_movies",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_syncInfo": {
          "type": "staticText",
          "text": "label_sync_info",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_help": {
          "type": "header",
          "text": "label_help",
          "size": 3
        },
        "_helpText": {
          "type": "staticText",
          "text": "label_help_text",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        }
      }
    }
  }
}
